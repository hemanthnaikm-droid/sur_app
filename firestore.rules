rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Emergency Contacts ──
    // Only the owner can read/write their own contacts
    match /contacts/{contactId} {
      allow read, delete: if request.auth != null
        && request.auth.uid == resource.data.uid;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.uid;
      allow update: if request.auth != null
        && request.auth.uid == resource.data.uid;
    }

    // ── SOS Logs ──
    // Only the owner can read/write their SOS logs
    match /sosLogs/{logId} {
      allow read, delete: if request.auth != null
        && request.auth.uid == resource.data.uid;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.uid;
    }

    // ── Community Safety Reports ──
    // Any authenticated user can read all reports
    // Only creator can delete their own report
    // Any authenticated user can create a report
    match /communityReports/{reportId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.uid;
      allow update: if request.auth != null;
    }

  }
}
