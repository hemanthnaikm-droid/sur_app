rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Emergency Contacts — only the owner can read/write
    match /contacts/{contactId} {
      allow read, update, delete: if request.auth != null
        && request.auth.uid == resource.data.uid;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.uid;
    }

    // Community Safety Reports — authenticated users can read all, write own
    match /communityReports/{reportId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.uid;
      allow update: if request.auth != null
        && (request.auth.uid == resource.data.uid || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votes','userVoted']));
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.uid;
    }

    // SOS Logs — only owner can read/write
    match /sosLogs/{logId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.uid;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.uid;
    }

  }
}
